<h1 class="page-title"><%= t("profile.title") %></h1>
<p class="page-subtitle"><%= t("profile.subtitle") %></p>

<section class="profile-stats card">
  <div class="profile-stats__header">
    <h2 class="card__title"><%= t("statistics.title") %></h2>
    <%= link_to t("statistics.download_csv"), profile_path(format: :csv), class: "btn btn--primary" %>
  </div>

  <div class="stats-table-wrap">
    <table class="stats-table">
      <thead>
        <tr>
          <th><%= t("statistics.image") %></th>
          <th><%= t("statistics.average_score") %></th>
          <th><%= t("statistics.evaluations_count") %></th>
        </tr>
      </thead>
      <tbody>
        <% @image_statistics.each do |stat| %>
          <tr>
            <td class="stats-table__image-cell">
              <%= image_tag stat.image_url, alt: stat.title, class: "stats-table__thumb", loading: "lazy" %>
              <span><%= stat.title %></span>
            </td>
            <td><%= stat.average_score.to_f.round(2) %></td>
            <td><%= stat.evaluations_count.to_i %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<div class="cards">
  <% @evaluations.each do |evaluation| %>
    <% image = evaluation.image %>
    <% theme = image.theme %>

    <article class="card card--profile">
      <%# Превью оценённого изображения (тот же URL, что и на странице темы). %>
      <div class="card__media">
        <%= image_tag image.image_url,
              alt: image.title,
              class: "card__image",
              loading: "lazy" %>
      </div>

      <div class="card__content">
        <h2 class="card__title"><%= image.title %></h2>
        <p class="card__body">
          <strong><%= t("profile.theme") %>:</strong>
          <%= theme.title %>
        </p>

        <p class="card__body">
          <strong><%= t("profile.your_score") %>:</strong>
          <%= evaluation.score %>
          <% if evaluation.comment.present? %>
            — <%= evaluation.comment %>
          <% end %>
        </p>

        <div class="card__actions">
          <%= link_to t("profile.open_theme"), theme_path(theme), class: "btn btn--secondary" %>
        </div>
      </div>
    </article>
  <% end %>
</div>

