<h1><%= t("themes.index.title") %></h1>

<div class="cards">
  <% @themes.each do |theme| %>
    <article class="card">
      <h2 class="card__title"><%= theme.title %></h2>
      <p class="card__body"><%= theme.description %></p>
      <div class="card__actions">
        <%= link_to t("themes.index.open"), theme_path(theme), class: "btn btn--secondary" %>
      </div>
    </article>
  <% end %>
</div>
