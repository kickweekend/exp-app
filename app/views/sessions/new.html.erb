<h1><%= t("auth.sign_in") %></h1>

<%= form_with url: session_path, class: "form" do |f| %>
  <div class="form__group">
    <%= label_tag :email, t("auth.email") %>
    <%= email_field_tag :email, nil, required: true %>
  </div>

  <div class="form__group">
    <%= label_tag :password, t("auth.password") %>
    <%= password_field_tag :password, nil, required: true %>
  </div>

  <div class="form__actions">
    <%= f.submit t("auth.sign_in"), class: "btn btn--primary" %>
  </div>
<% end %>
