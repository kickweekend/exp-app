<h1><%= t("auth.sign_up") %></h1>

<%= form_with model: @user, url: registrations_path, class: "form" do |f| %>
  <div class="form__group">
    <%= f.label :name, t("auth.name") %>
    <%= f.text_field :name, required: true %>
  </div>

  <div class="form__group">
    <%= f.label :email, t("auth.email") %>
    <%= f.email_field :email, required: true %>
  </div>

  <div class="form__group">
    <%= f.label :password, t("auth.password") %>
    <%= f.password_field :password, required: true %>
  </div>

  <div class="form__group">
    <%= f.label :password_confirmation, t("auth.password_confirmation") %>
    <%= f.password_field :password_confirmation, required: true %>
  </div>

  <div class="form__actions">
    <%= f.submit t("auth.sign_up"), class: "btn btn--primary" %>
  </div>
<% end %>
